{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexe.local/schemas/node_capability_declaration_manifest.schema.json",
  "title": "Node Capability Declaration Manifest",
  "description": "JSON Schema for the capability manifest accepted by Core at POST /system/nodes/capabilities/declaration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "node",
    "declared_task_families",
    "supported_providers",
    "node_features",
    "environment_hints"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1.0",
      "description": "Supported capability declaration schema version."
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "node_name",
        "node_software_version"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^node-.*$"
        },
        "node_type": {
          "type": "string",
          "minLength": 2,
          "maxLength": 64
        },
        "node_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "node_software_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "declared_task_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._/-]{1,127}$"
      },
      "description": "Declared task families. Core lowercases and de-duplicates these during validation."
    },
    "supported_providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"
      },
      "description": "Provider identifiers the node can support."
    },
    "enabled_providers": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"
      },
      "description": "Subset of supported_providers that are currently enabled."
    },
    "node_features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "telemetry": {
          "type": "boolean",
          "default": false
        },
        "governance_refresh": {
          "type": "boolean",
          "default": false
        },
        "lifecycle_events": {
          "type": "boolean",
          "default": false
        },
        "provider_failover": {
          "type": "boolean",
          "default": false
        }
      },
      "default": {}
    },
    "environment_hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployment_target": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "acceleration": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "network_tier": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        },
        "region": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 64
        }
      },
      "default": {}
    },
    "provider_intelligence": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"
          },
          "available_models": {
            "type": "array",
            "default": [],
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "model_id"
              ],
              "properties": {
                "model_id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "pricing": {
                  "type": "object",
                  "default": {},
                  "propertyNames": {
                    "minLength": 1
                  },
                  "additionalProperties": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "latency_metrics": {
                  "type": "object",
                  "default": {},
                  "propertyNames": {
                    "minLength": 1
                  },
                  "additionalProperties": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      },
      "description": "Optional provider capability metadata reported by the node."
    }
  },
  "$comment": "JSON Schema cannot fully express Core's case-normalizing subset checks for enabled_providers and provider_intelligence membership. Those rules are still enforced server-side."
}
