{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexe.local/schemas/node_notification_result.schema.json",
  "title": "Node Notification Result",
  "description": "JSON Schema for Core-published notification proxy results on hexe/nodes/<node_id>/notify/result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "node_id",
    "status",
    "accepted",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected"
      ]
    },
    "accepted": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "notification_id": {
      "type": "string"
    },
    "internal_topic": {
      "type": "string"
    },
    "error": {
      "type": "string"
    },
    "requested_external_targets": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
