# Hexe AI shared script configuration
# This file is sourced by scripts in this directory.
# Uncomment and edit values as needed.

# Public-facing platform branding (Phase 0 cosmetic rebrand)
PLATFORM_NAME="Hexe AI"
PLATFORM_SHORT="Hexe"
PLATFORM_DOMAIN="hexe-ai.com"
PLATFORM_CORE_NAME="Hexe Core"
PLATFORM_SUPERVISOR_NAME="Hexe Supervisor"
PLATFORM_NODES_NAME="Hexe Nodes"
PLATFORM_ADDONS_NAME="Hexe Addons"
PLATFORM_DOCS_NAME="Hexe Docs"

# Repo source for bootstrap
REPO_URL="https://github.com/danhajduk/SynthiaCore.git"

# Backend address for frontend proxy config
SYNTHIA_BACKEND_HOST="10.0.0.100"
SYNTHIA_BACKEND_PORT="9001"
SYNTHIA_NODE_ONBOARDING_APPROVAL_URL_BASE="http://10.0.0.100/onboarding/registrations/approve"
# Legacy alias still supported by backend for compatibility:
# SYNTHIA_AI_NODE_ONBOARDING_APPROVAL_URL_BASE="http://10.0.0.100/onboarding/registrations/approve"

# Update log file
LOG_FILE="/tmp/synthia_update.log"

# Optional log levels for backend file logs
SYNTHIA_LOG_ADDONS_LEVEL="DEBUG"
SYNTHIA_LOG_API_LEVEL="DEBUG"
SYNTHIA_LOG_CORE_LEVEL="DEBUG"
SYNTHIA_LOG_SYSTEM_LEVEL="DEBUG"

# Core semantic version used by addon compatibility resolver.
# Keep this aligned to the deployed Hexe Core release.
SYNTHIA_CORE_VERSION="0.6.0"

# Standalone-service addon state root used by SSAP flows.
# Default resolves to sibling ../SynthiaAddons (outside repo) when unset.
# Recommended for updater-safe persistence: use a path outside this repo.
# Example: SYNTHIA_ADDONS_DIR="$HOME/.local/share/hexe/HexeAddons"
