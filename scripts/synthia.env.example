# Synthia shared script configuration
# This file is sourced by scripts in this directory.
# Uncomment and edit values as needed.

# Repo source for bootstrap
REPO_URL="https://github.com/danhajduk/SynthiaCore.git"

# Backend address for frontend proxy config
SYNTHIA_BACKEND_HOST="10.0.0.100"
SYNTHIA_BACKEND_PORT="9001"

# Update log file
LOG_FILE="/tmp/synthia_update.log"

# Optional log levels for backend file logs
SYNTHIA_LOG_ADDONS_LEVEL="DEBUG"
SYNTHIA_LOG_API_LEVEL="DEBUG"
SYNTHIA_LOG_CORE_LEVEL="DEBUG"
SYNTHIA_LOG_SYSTEM_LEVEL="DEBUG"

# Core semantic version used by addon compatibility resolver.
# Keep this aligned to the deployed Synthia Core release.
SYNTHIA_CORE_VERSION="0.6.0"

# Standalone-service addon state root used by SSAP flows.
# Default resolves to <repo>/SynthiaAddons when unset.
# Recommended for updater-safe persistence: use a path outside this repo.
# Example: SYNTHIA_ADDONS_DIR="$HOME/.local/share/synthia/SynthiaAddons"

# Emergency-only: bypass remote catalog signature verification during refresh.
# Keep unset/false in normal operation.
# ALLOW_INSECURE_CATALOG="false"
